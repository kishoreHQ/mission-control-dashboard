# Environment Configuration

# Connection mode: local | tailscale | api
VITE_CONNECTION_MODE=tailscale

# VPS Tailscale IP (get with: tailscale ip -4 on VPS)
VITE_VPS_TAILSCALE_IP=100.64.123.45

# VPS hostname (for Tailscale SSH)
VITE_VPS_HOSTNAME=vps-hermes

# VPS SSH user
VITE_VPS_USER=root

# SSH private key path (for remote data fetching)
# VITE_VPS_SSH_KEY=~/.ssh/id_ed25519

# Dashboard settings
VITE_REFRESH_INTERVAL=30
VITE_DEFAULT_THEME=dark

# Feature flags
VITE_ENABLE_REALTIME=false
VITE_ENABLE_NOTIFICATIONS=false
